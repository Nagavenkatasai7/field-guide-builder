# Copy to .env.local and fill in. Same values must be set in Vercel project env.

# 32+ char access password. Generate with: openssl rand -hex 16
AUTH_PASSWORD=

# 32+ char HMAC secret for signing the auth cookie. Generate with: openssl rand -hex 32
AUTH_COOKIE_SECRET=

# === Author identity (make this template yours) ===
# These set who the guides and LinkedIn posts are published as. All optional —
# generic placeholders are used when unset — but set them before going public.
# AUTHOR_NAME      — your real name / byline (e.g. Jane Doe)
# AUTHOR_BRAND     — your channel or series name (e.g. Learn with Jane)
# AUTHOR_HASHTAG   — your signature hashtag; MUST start with '#' (e.g. #LearnWithJane)
# AUTHOR_YOUTUBE   — channel URL/handle; leave blank to omit it (e.g. youtube.com/@handle)
# AUTHOR_ROLE      — one-line professional descriptor; reads after "is …"
#                    (e.g. a data analyst who explains AI workflows in plain English)
# AUTHOR_BIO       — short author bio shown in the PDF colophon
# AUTHOR_AUDIENCE  — who you write for (e.g. analysts, ops leaders, and builders)
AUTHOR_NAME=
AUTHOR_BRAND=
AUTHOR_HASHTAG=
AUTHOR_YOUTUBE=
AUTHOR_ROLE=
AUTHOR_BIO=
AUTHOR_AUDIENCE=

# https://tavily.com/  → free tier is plenty for personal use
TAVILY_API_KEY=

# Ollama Cloud API key — https://ollama.com/settings/keys
# Used for plan, draft, SVG, and LinkedIn-post generation (M3+).
OLLAMA_API_KEY=

# Optional LLM overrides. Defaults are gemma4:31b-cloud with no fallback.
# To enable retry-on-error, set a fallback you have plan access to, e.g.:
#   LLM_FALLBACK_MODEL=gpt-oss:120b-cloud
# (Note: kimi-k2.6:cloud requires the paid Ollama Cloud tier.)
# LLM_PRIMARY_MODEL=gemma4:31b-cloud
# LLM_FALLBACK_MODEL=

# === LinkedIn daily auto-post (M9) ===
# From your LinkedIn Developer app (developer.linkedin.com → your app → Auth).
# Enable products: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect".
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# MUST exactly match an Authorized redirect URL registered in the app.
# Local: http://localhost:3838/auth/linkedin/callback
# Prod (if connecting on the deployed site): https://<your-app>.vercel.app/auth/linkedin/callback
LINKEDIN_REDIRECT_URI=http://localhost:3838/auth/linkedin/callback
# LinkedIn versioned API header (YYYYMM). 202505 and earlier are sunset.
LINKEDIN_API_VERSION=202509

# Secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`. Generate
# with: openssl rand -hex 32 . Set the SAME value in Vercel project env.
CRON_SECRET=

# Email alerts (Resend). Dormant until RESEND_API_KEY is set — then emails on
# every post / block / failure / token-expiry. https://resend.com
RESEND_API_KEY=
# Recipient for alert emails. Leave unset to skip email alerts entirely.
ALERT_EMAIL_TO=you@example.com
# ALERT_EMAIL_FROM defaults to Resend's onboarding sender; override with a
# verified sender once your domain is set up in Resend.
# ALERT_EMAIL_FROM=Field Guide Bot <onboarding@resend.dev>

# Emergency kill switch: set to 1 to stop ALL auto-posting before any DB read.
# AUTOMATION_DISABLED=1

# === Approval mode (M12) ===
# Optional explicit origin for links placed in alert emails (the /approve
# page). When unset, falls back to the origin of LINKEDIN_REDIRECT_URI, then
# Vercel's production domain — so most setups never need this.
# APP_BASE_URL=https://your-app.vercel.app
